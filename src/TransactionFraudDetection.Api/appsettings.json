{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FailedPublishDirectory": "failed-publishes",
  "FraudRules": {
    "HighAmountThreshold": 5000,
    "HighAmountScore": 50,
    "VelocityWindowMinutes": 5,
    "VelocityMaxTransactionsInWindow": 3,
    "VelocityScore": 40,
    "GeoMismatchScore": 30,
    "OddHoursWindowStartHour": 1,
    "OddHoursWindowEndHour": 5,
    "OddHoursScore": 20,
    "RiskThreshold": 50
  }
}
